graph TD
    %% Styling
    classDef pi fill:#c51a4a,stroke:#333,stroke-width:2px,color:#fff;
    classDef hormann fill:#d3d3d3,stroke:#333,stroke-width:2px;
    classDef sensor fill:#e1f5fe,stroke:#0288d1,stroke-width:2px;
    classDef switch fill:#fff9c4,stroke:#fbc02d,stroke-width:2px;

    %% Netwerk
    Netwerk((Internet)) -->|Ethernetkabel| Pi[Raspberry Pi Model 1 B+]
    class Pi pi;

    %% Componenten aan Pi
    NFC[NFC Lezer buiten<br>RFID RC522] -.->|NFC data via GPIO| Pi
    class NFC sensor;

    Pi -->|Schakelt| Relais[Relais Module]

    %% Garagedeur en motor
    Relais -->|Maakcontact puls| Motor[Hormann Motor<br>Open -> Stop -> Sluit]
    class Motor hormann;

    %% Handmatige schakelaars
    Hal[Wandschakelaar Hal] -->|Maakcontact puls| Motor
    Garage[Wandschakelaar Garage] -->|Maakcontact puls| Motor
    class Hal,Garage switch;

    %% Deur en Sensoren
    subgraph Fysieke Deur
        Deur[Garagedeur met Magneten]
    end

    Deur -.->|Magneet bij open| Reed1[Reed Contact 1<br>Volledig Open]
    Deur -.->|Magneet bij dicht| Reed2[Reed Contact 2<br>Volledig Gesloten]
    class Reed1,Reed2 sensor;

    Reed1 -->|Status signaal| Pi
    Reed2 -->|Status signaal| Pi